{
  "name": "shiqingqi.com",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "watch:i18n": "tsx tooling/i18n-codegen/generator.ts --watch",
    "prebuild": "npm-run-all codegen:pwa-icons codegen:i18n",
    "codegen": "npm-run-all codegen:*",
    "codegen:i18n": "tsx tooling/i18n-codegen/generator.ts",
    "codegen:openapi": "openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o src/_generated/tmdbV3.d.ts && prettier 'src/_generated/tmdbV3.d.ts' -w",
    "codegen:pwa-icons": "node tooling/pwa-icons/hash-icons.mjs",
    "codegen:tmdb": "node tooling/tmdb-codegen/generator.js && prettier 'src/_generated/*.ts' -w",
    "codegen:zod": "tsx tooling/tmdb-codegen/generate-selective-zod.ts && prettier 'src/_generated/tmdb-zod.ts' -w",
    "dev": "run-p watch:i18n dev:next",
    "dev:next": "next dev --turbopack",
    "build": "next build && serwist build serwist.config.mjs",
    "build:tsc": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "lint:changed": "(git diff --name-only --diff-filter=d HEAD; git ls-files --others --exclude-standard) | grep -E '\\.(js|jsx|ts|tsx)$' | sort -u | xargs -r eslint --fix",
    "format:write": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,md,mjs}' --ignore-path .gitignore",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,css,md,mjs}' --ignore-path .gitignore",
    "format:changed": "git diff --name-only --diff-filter=d HEAD | grep -E '\\.(js|jsx|ts|tsx|json|css|md|mjs)$' | xargs -r prettier --write",
    "pretest": "pnpm codegen:i18n",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "eval": "vitest run --config vitest.eval.config.mts",
    "eval:dev": "vitest --config vitest.eval.config.mts",
    "ingest:vector": "tsx tooling/vector-ingest/ingest.ts",
    "verify:vector": "tsx tooling/vector-ingest/verify.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/react": "^3.0.166",
    "@phosphor-icons/react": "^2.1.10",
    "@serwist/next": "^9.5.7",
    "@stylexjs/stylex": "^0.18.2",
    "@tanstack/react-query": "5.99.0",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "^6.0.164",
    "next": "16.2.4",
    "react": "19.3.0-canary-56824423-20260414",
    "react-dom": "19.3.0-canary-56824423-20260414",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "^2.7.2",
    "react-virtuoso": "^4.18.5",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.7",
    "sharp": "^0.34.5",
    "twgl.js": "^7.0.0",
    "zod": "4"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/parser": "^7.29.2",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@serwist/cli": "^9.5.7",
    "@stylexjs/babel-plugin": "^0.18.2",
    "@stylexjs/eslint-plugin": "^0.18.2",
    "@stylexjs/postcss-plugin": "^0.18.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-react-compiler": "19.0.0-beta-714736e-20250131",
    "dotenv": "^17.4.2",
    "esbuild-wasm": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "jsdom": "^29.0.2",
    "modern-normalize": "^3.0.1",
    "msw": "^2.13.3",
    "next-i18n-router": "^5.5.7",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.2.1",
    "prettier": "^3.8.3",
    "raw-loader": "^4.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
