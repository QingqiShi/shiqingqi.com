{
  "name": "shiqingqi.com",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "scripts": {
    "dev": "pnpm --filter @qi/site dev",
    "build": "pnpm -r build",
    "build:tsc": "pnpm -r build:tsc",
    "start": "pnpm --filter @qi/site start",
    "test": "pnpm -r test",
    "test:ui": "pnpm --filter @qi/site test:ui",
    "test:coverage": "pnpm --filter @qi/site test:coverage",
    "test:e2e": "pnpm --filter @qi/site test:e2e",
    "watch:i18n": "pnpm -r watch:i18n",
    "codegen": "pnpm -r codegen",
    "codegen:i18n": "pnpm -r codegen:i18n",
    "codegen:openapi": "pnpm -r codegen:openapi",
    "codegen:pwa-icons": "pnpm -r codegen:pwa-icons",
    "codegen:tmdb": "pnpm -r codegen:tmdb",
    "codegen:zod": "pnpm -r codegen:zod",
    "ingest:vector": "pnpm -r ingest:vector",
    "verify:vector": "pnpm -r verify:vector",
    "eval": "pnpm -r eval",
    "eval:dev": "pnpm -r eval:dev",
    "lint": "eslint .",
    "lint:changed": "(git diff --name-only --diff-filter=d HEAD; git ls-files --others --exclude-standard) | grep -E '\\.(js|jsx|ts|tsx)$' | sort -u | xargs -r eslint --fix",
    "format:write": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,md,mjs}' --ignore-path .gitignore",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,css,md,mjs}' --ignore-path .gitignore",
    "format:changed": "git diff --name-only --diff-filter=d HEAD | grep -E '\\.(js|jsx|ts|tsx|json|css|md|mjs)$' | xargs -r prettier --write"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@stylexjs/eslint-plugin": "^0.18.3",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
