{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "watch:i18n": "tsx ../../packages/i18n-codegen/src/generator.ts --watch",
    "prebuild": "npm-run-all codegen:pwa-icons codegen:i18n codegen:palette",
    "codegen": "npm-run-all codegen:*",
    "codegen:i18n": "tsx ../../packages/i18n-codegen/src/generator.ts",
    "codegen:palette": "node --experimental-strip-types --no-warnings ../../packages/system-palette-codegen/src/generator.ts && prettier '../../packages/ui/src/_generated/palette/**/*.ts' -w",
    "codegen:pwa-icons": "node ../../packages/pwa-icons/src/hash-icons.mjs",
    "codegen:tmdb": "node ../../packages/tmdb-codegen/src/generator.js && prettier 'src/_generated/*.ts' -w",
    "codegen:zod": "tsx ../../packages/tmdb-codegen/src/generate-selective-zod.ts && prettier 'src/_generated/tmdb-zod.ts' -w",
    "openapi:generate": "openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o ../../packages/tmdb-types/src/openapi.d.ts && prettier '../../packages/tmdb-types/src/openapi.d.ts' -w",
    "predev": "npm-run-all codegen:i18n codegen:palette",
    "dev": "run-p watch:i18n dev:next",
    "dev:next": "next dev --turbopack -p $(node ../../scripts/worktree-port.mjs)",
    "build": "next build && serwist build serwist.config.mjs",
    "build:tsc": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "npm-run-all codegen:i18n codegen:palette",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "eval": "vitest run --config vitest.eval.config.mts",
    "eval:dev": "vitest --config vitest.eval.config.mts",
    "ingest:vector": "tsx ../../packages/vector-ingest/src/ingest.ts",
    "verify:vector": "tsx ../../packages/vector-ingest/src/verify.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/react": "^4.0.22",
    "@phosphor-icons/react": "^2.1.10",
    "@serwist/next": "catalog:",
    "@stylexjs/stylex": "catalog:",
    "@tanstack/react-query": "5.101.2",
    "@tuja/tmdb-types": "workspace:*",
    "@tuja/ui": "workspace:*",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@upstash/vector": "catalog:",
    "@vercel/analytics": "catalog:",
    "@vercel/speed-insights": "catalog:",
    "ai": "^7.0.21",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "catalog:",
    "react-virtuoso": "^4.18.10",
    "remark-gfm": "^4.0.1",
    "serwist": "catalog:",
    "sharp": "^0.35.3",
    "twgl.js": "^7.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/preset-env": "catalog:",
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@babel/runtime": "^8.0.0",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@playwright/test": "^1.61.0",
    "@rolldown/plugin-babel": "catalog:",
    "@serwist/cli": "catalog:",
    "@stylexjs/babel-plugin": "catalog:",
    "@stylexjs/postcss-plugin": "^0.19.0",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@tuja/babel-plugin-stylex-breakpoints": "workspace:*",
    "@tuja/babel-plugin-stylex-css-prop": "workspace:*",
    "@tuja/i18n-babel-plugin": "workspace:*",
    "@tuja/i18n-codegen": "workspace:*",
    "@tuja/pwa-icons": "workspace:*",
    "@tuja/tmdb-codegen": "workspace:*",
    "@tuja/tsconfig": "workspace:*",
    "@tuja/vector-ingest": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv": "catalog:",
    "esbuild-wasm": "^0.28.1",
    "jsdom": "catalog:",
    "modern-normalize": "^3.0.1",
    "msw": "^2.15.0",
    "next-i18n-router": "^5.5.8",
    "npm-run-all2": "^9.0.2",
    "openapi-typescript": "^7.13.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "catalog:",
    "raw-loader": "^4.0.2",
    "react-grab": "^0.1.48",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
