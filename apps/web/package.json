{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "watch:i18n": "tsx ../../packages/i18n-codegen/src/generator.ts --watch",
    "prebuild": "npm-run-all codegen:pwa-icons codegen:i18n codegen:palette",
    "codegen": "npm-run-all codegen:*",
    "codegen:i18n": "tsx ../../packages/i18n-codegen/src/generator.ts",
    "codegen:openapi": "openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o ../../packages/tmdb-types/src/openapi.d.ts && prettier '../../packages/tmdb-types/src/openapi.d.ts' -w",
    "codegen:palette": "node --experimental-strip-types --no-warnings ../../packages/system-palette-codegen/src/generator.ts && prettier '../../packages/ui/src/_generated/palette/**/*.ts' -w",
    "codegen:pwa-icons": "node ../../packages/pwa-icons/src/hash-icons.mjs",
    "codegen:tmdb": "node ../../packages/tmdb-codegen/src/generator.js && prettier 'src/_generated/*.ts' -w",
    "codegen:zod": "tsx ../../packages/tmdb-codegen/src/generate-selective-zod.ts && prettier 'src/_generated/tmdb-zod.ts' -w",
    "predev": "npm-run-all codegen:i18n codegen:palette",
    "dev": "run-p watch:i18n dev:next",
    "dev:next": "next dev --turbopack -p $(node ../../scripts/worktree-port.mjs)",
    "build": "next build && serwist build serwist.config.mjs",
    "build:tsc": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "npm-run-all codegen:i18n codegen:palette",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "eval": "vitest run --config vitest.eval.config.mts",
    "eval:dev": "vitest --config vitest.eval.config.mts",
    "ingest:vector": "tsx ../../packages/vector-ingest/src/ingest.ts",
    "verify:vector": "tsx ../../packages/vector-ingest/src/verify.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.7",
    "@ai-sdk/react": "^4.0.15",
    "@phosphor-icons/react": "^2.1.10",
    "@serwist/next": "^9.5.11",
    "@stylexjs/stylex": "^0.19.0",
    "@tanstack/react-query": "5.101.2",
    "@tuja/tmdb-types": "workspace:*",
    "@tuja/ui": "workspace:*",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "^7.0.14",
    "next": "16.2.10",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "^2.7.2",
    "react-virtuoso": "^4.18.10",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.11",
    "sharp": "^0.35.3",
    "twgl.js": "^7.0.0",
    "zod": "4"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/parser": "^8.0.0",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@playwright/test": "^1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@serwist/cli": "^9.5.11",
    "@stylexjs/babel-plugin": "^0.19.0",
    "@stylexjs/postcss-plugin": "^0.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tuja/babel-plugin-stylex-breakpoints": "workspace:*",
    "@tuja/babel-plugin-stylex-css-prop": "workspace:*",
    "@tuja/i18n-babel-plugin": "workspace:*",
    "@tuja/i18n-codegen": "workspace:*",
    "@tuja/pwa-icons": "workspace:*",
    "@tuja/tmdb-codegen": "workspace:*",
    "@tuja/tsconfig": "workspace:*",
    "@tuja/vector-ingest": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.9.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-react-compiler": "19.0.0-beta-714736e-20250131",
    "dotenv": "^17.4.2",
    "esbuild-wasm": "^0.28.1",
    "jsdom": "^29.1.1",
    "modern-normalize": "^3.0.1",
    "msw": "^2.14.6",
    "next-i18n-router": "^5.5.8",
    "npm-run-all2": "^9.0.2",
    "openapi-typescript": "^7.13.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "^3.9.4",
    "raw-loader": "^4.0.2",
    "react-grab": "^0.1.48",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
