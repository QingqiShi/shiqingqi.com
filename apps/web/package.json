{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "watch:i18n": "tsx ../../packages/i18n-codegen/generator.ts --watch",
    "prebuild": "npm-run-all codegen:pwa-icons codegen:i18n",
    "codegen": "npm-run-all codegen:*",
    "codegen:i18n": "tsx ../../packages/i18n-codegen/generator.ts",
    "codegen:openapi": "openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o ../../packages/tmdb-types/openapi.d.ts && prettier '../../packages/tmdb-types/openapi.d.ts' -w",
    "codegen:pwa-icons": "node ../../packages/pwa-icons/hash-icons.mjs",
    "codegen:tmdb": "node ../../packages/tmdb-codegen/generator.js && prettier 'src/_generated/*.ts' -w",
    "codegen:zod": "tsx ../../packages/tmdb-codegen/generate-selective-zod.ts && prettier 'src/_generated/tmdb-zod.ts' -w",
    "dev": "run-p watch:i18n dev:next",
    "dev:next": "next dev --turbopack",
    "build": "next build && serwist build serwist.config.mjs",
    "build:tsc": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "eval": "vitest run --config vitest.eval.config.mts",
    "eval:dev": "vitest --config vitest.eval.config.mts",
    "ingest:vector": "tsx ../../packages/vector-ingest/ingest.ts",
    "verify:vector": "tsx ../../packages/vector-ingest/verify.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/react": "^3.0.170",
    "@phosphor-icons/react": "^2.1.10",
    "@tuja/tmdb-types": "workspace:*",
    "@serwist/next": "^9.5.7",
    "@stylexjs/stylex": "^0.18.3",
    "@tanstack/react-query": "5.100.6",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "^6.0.168",
    "next": "16.2.4",
    "react": "19.3.0-canary-56824423-20260414",
    "react-dom": "19.3.0-canary-56824423-20260414",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "^2.7.2",
    "react-virtuoso": "^4.18.6",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.7",
    "sharp": "^0.34.5",
    "twgl.js": "^7.0.0",
    "zod": "4"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/parser": "^7.29.2",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.59.1",
    "@tuja/babel-plugin-stylex-breakpoints": "workspace:*",
    "@tuja/babel-plugin-stylex-css-prop": "workspace:*",
    "@tuja/i18n-babel-plugin": "workspace:*",
    "@tuja/i18n-codegen": "workspace:*",
    "@tuja/pwa-icons": "workspace:*",
    "@tuja/tmdb-codegen": "workspace:*",
    "@tuja/tsconfig": "workspace:*",
    "@tuja/vector-ingest": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@serwist/cli": "^9.5.7",
    "@stylexjs/babel-plugin": "^0.18.3",
    "@stylexjs/postcss-plugin": "^0.18.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-react-compiler": "19.0.0-beta-714736e-20250131",
    "dotenv": "^17.4.2",
    "esbuild-wasm": "^0.28.0",
    "jsdom": "^29.1.1",
    "modern-normalize": "^3.0.1",
    "msw": "^2.14.2",
    "next-i18n-router": "^5.5.8",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.2.1",
    "raw-loader": "^4.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
