{
  "extends": "@tuja/tsconfig/nextjs.json",
  "compilerOptions": {
    "types": ["node", "@serwist/next/typings"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    "serwist.config.mjs"
  ],
  "exclude": ["node_modules", "public/*", ".next/**"]
}
