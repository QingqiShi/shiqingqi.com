{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": [
    "GITHUB_STEP_SUMMARY",
    "CI",
    "BASE_URL",
    "DESIGN_AUTHOR_TOKENS_PATH",
    "ANTHROPIC_API_KEY",
    "TMDB_API_TOKEN",
    "UPSTASH_VECTOR_REST_URL",
    "UPSTASH_VECTOR_REST_TOKEN",
    "UPSTASH_VECTOR_REST_READONLY_TOKEN",
    "VERCEL_URL",
    "VERCEL_BRANCH_URL",
    "KV_REST_API_URL",
    "KV_URL",
    "REDIS_URL",
    "KV_REST_API_TOKEN",
    "KV_REST_API_READ_ONLY_TOKEN",
    "SITE_PASSWORD_GB",
    "SITE_PASSWORD_TUSCANY"
  ],
  "tasks": {
    "codegen": {
      "outputs": [
        "src/_generated/**",
        "public/sw.js",
        "public/pwa-*.png",
        "src/app/manifest.json"
      ],
      "inputs": ["src/**/*.{ts,tsx,js,mjs,json}", "$TURBO_DEFAULT$"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "public/sw.js"]
    },
    "build:tsc": {
      "dependsOn": ["^build", "codegen"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [],
      "env": ["UPSTASH_REDIS_REST_URL"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
