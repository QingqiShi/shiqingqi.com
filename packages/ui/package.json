{
  "name": "@tuja/ui",
  "version": "0.0.0",
  "description": "StyleX design system powering qingqi.dev: role-based light-dark() tokens, a generated 13-hue HCT palette, composable primitives, and accessible React components.",
  "keywords": [
    "stylex",
    "react",
    "design-system",
    "components",
    "design-tokens",
    "light-dark",
    "hct"
  ],
  "homepage": "https://qingqi.dev/en/design-system",
  "bugs": {
    "url": "https://github.com/QingqiShi/shiqingqi.com/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QingqiShi/shiqingqi.com.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Qingqi Shi <hi@qingqi.dev>",
  "type": "module",
  "sideEffects": [
    "**/*.stylex.ts"
  ],
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/test-setup.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./package.json": "./package.json",
    "./css-prop": "./src/css-prop.d.ts",
    "./css-prop-types": "./src/css-prop-types.ts",
    "./tokens.stylex": "./src/tokens.stylex.ts",
    "./breakpoints.stylex": "./src/breakpoints.stylex.ts",
    "./palette/*": "./src/_generated/palette/hues/*.stylex.ts",
    "./palette-table": "./src/_generated/palette/palette-table.ts",
    "./author/token-registry": "./src/author/token-registry.ts",
    "./author/palette-match": "./src/author/palette-match.ts",
    "./hooks/use-controlled": "./src/hooks/use-controlled.ts",
    "./hooks/use-dialog-focus": "./src/hooks/use-dialog-focus.ts",
    "./hooks/use-press-animation": "./src/hooks/use-press-animation.ts",
    "./hooks/use-press-handlers": "./src/hooks/use-press-handlers.ts",
    "./hooks/use-radio-group": "./src/hooks/use-radio-group.ts",
    "./primitives/a11y.stylex": "./src/primitives/a11y.stylex.ts",
    "./primitives/flex.stylex": "./src/primitives/flex.stylex.ts",
    "./primitives/layout.stylex": "./src/primitives/layout.stylex.ts",
    "./primitives/motion.stylex": "./src/primitives/motion.stylex.ts",
    "./primitives/reset.stylex": "./src/primitives/reset.stylex.ts",
    "./components/anchor.stylex": "./src/components/anchor.stylex.ts",
    "./components/anchor-button-group": "./src/components/anchor-button-group.tsx",
    "./components/animate-to-target": "./src/components/animate-to-target.tsx",
    "./components/badge": "./src/components/badge.tsx",
    "./components/button": "./src/components/button.tsx",
    "./components/button.stylex": "./src/components/button.stylex.ts",
    "./components/button-shared.stylex": "./src/components/button-shared.stylex.ts",
    "./components/callout": "./src/components/callout.tsx",
    "./components/card": "./src/components/card.tsx",
    "./components/card.stylex": "./src/components/card.stylex.ts",
    "./components/checkbox": "./src/components/checkbox.tsx",
    "./components/divider": "./src/components/divider.tsx",
    "./components/field-shared.stylex": "./src/components/field-shared.stylex.ts",
    "./components/fixed-container-content": "./src/components/fixed-container-content.tsx",
    "./components/header-footer-layout": "./src/components/header-footer-layout.tsx",
    "./components/heading": "./src/components/heading.tsx",
    "./components/icon-button": "./src/components/icon-button.tsx",
    "./components/menu-button": "./src/components/menu-button.tsx",
    "./components/menu-label": "./src/components/menu-label.tsx",
    "./components/overlay": "./src/components/overlay.tsx",
    "./components/select": "./src/components/select.tsx",
    "./components/sidebar-layout": "./src/components/sidebar-layout.tsx",
    "./components/skeleton": "./src/components/skeleton.tsx",
    "./components/skeleton.stylex": "./src/components/skeleton.stylex.ts",
    "./components/spinner": "./src/components/spinner.tsx",
    "./components/switch": "./src/components/switch.tsx",
    "./components/switch.stylex": "./src/components/switch.stylex.ts",
    "./components/text": "./src/components/text.tsx",
    "./components/text-field": "./src/components/text-field.tsx",
    "./components/textarea": "./src/components/textarea.tsx"
  },
  "scripts": {
    "build:tsc": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "react-remove-scroll": "^2.7.2"
  },
  "peerDependencies": {
    "@stylexjs/stylex": "^0.19.0",
    "react": ">=19.2.0 <20",
    "react-dom": ">=19.2.0 <20"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@stylexjs/babel-plugin": "^0.19.0",
    "@stylexjs/stylex": "^0.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tuja/babel-plugin-stylex-breakpoints": "workspace:*",
    "@tuja/babel-plugin-stylex-css-prop": "workspace:*",
    "@tuja/tsconfig": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
